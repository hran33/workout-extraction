# Copy this file to .env and fill in your API keys.

# --- Provider: RapidAPI (Xiaohongshu Downloader) ---
# Sign up at https://rapidapi.com and search for a Xiaohongshu / RedNote downloader API.
# Set the host and key values for the API you subscribe to.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=rednote-videos-images-download.p.rapidapi.com

# --- Active provider ---
# Which provider module to use. Must match a file in src/providers/.
# Currently supported: "xiaohongshuProvider"
PROVIDER=xiaohongshuProvider
